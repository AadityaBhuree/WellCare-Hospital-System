# ── Application Settings ─────────────────────────────────────
APP_TITLE=WellCare Hospital Patient Management
APP_GEOMETRY=1440x1024
APP_MIN_WIDTH=900
APP_MIN_HEIGHT=700

# ── Appearance ────────────────────────────────────────────────
# Options: Light | Dark
APPEARANCE_MODE=Light
COLOR_THEME=blue

# ── Authentication (bcrypt hashes) ────────────────────────────
# Generate hashes with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'<password>', bcrypt.gensalt()).decode())"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
STAFF_USERNAME=staff
STAFF_PASSWORD_HASH=

# ── Dashboard ─────────────────────────────────────────────────
AUTO_REFRESH_INTERVAL_MS=10000
